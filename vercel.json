{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.html"
    }
  ]
}
